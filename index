<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Contraarchivo de libros prohibidos</title>

  <style>
    body {
      margin: 0;
      min-height: 100vh;
      background-image: url("background.jpg");
      background-size: cover;
      background-position: center;
      background-repeat: no-repeat;
      overflow: hidden;
      font-family: Georgia, "Times New Roman", serif;
    }

    .book {
      position: absolute;
      top: 200px;
      left: 200px;
      width: 120px;
      cursor: grab;
      z-index: 2;
      transition: transform 0.2s ease;
    }

    .book:hover {
      transform: scale(1.05);
    }

    .book:active {
      cursor: grabbing;
    }

    .popup {
      position: absolute;
      top: 170px;
      left: 340px;
      width: 440px;
      max-height: 540px;
      background: rgba(255, 248, 235, 0.96);
      border: 2px solid #4b2e1f;
      border-radius: 12px;
      box-shadow: 0 8px 25px rgba(0, 0, 0, 0.35);
      z-index: 5;
      display: none;
      overflow: hidden;
    }

    .popup.show {
      display: block;
    }

    .tabs {
      display: flex;
      background: #4b2e1f;
    }

    .tab-button {
      flex: 1;
      padding: 12px;
      border: none;
      background: #4b2e1f;
      color: white;
      font-size: 15px;
      font-weight: bold;
      cursor: pointer;
      font-family: Georgia, "Times New Roman", serif;
    }

    .tab-button.active {
      background: #8b5e3c;
    }

    .tab-content {
      display: none;
      padding: 18px;
      overflow-y: auto;
      max-height: 470px;
      font-size: 15px;
      line-height: 1.45;
      color: #2a1a12;
    }

    .tab-content.active {
      display: block;
    }

    .tab-content p {
      margin: 0 0 12px;
    }

    .label {
      font-weight: bold;
    }

    .fill-box {
      min-height: 90px;
      padding: 10px;
      margin-top: 6px;
      margin-bottom: 14px;
      border: 1.5px dashed #8b5e3c;
      border-radius: 8px;
      background: rgba(255, 255, 255, 0.65);
      color: #5a3a28;
    }

    .contraarchivo-box {
      min-height: 260px;
      padding: 12px;
      border: 1.5px dashed #8b5e3c;
      border-radius: 8px;
      background: rgba(255, 255, 255, 0.7);
      color: #5a3a28;
      line-height: 1.5;
    }
  </style>
</head>

<body>

  <img
    src="cover_La_casa_en_Mango_Street.jpg"
    alt="Portada de La casa en Mango Street"
    class="book"
    id="book"
  />

  <div class="popup" id="popup">
    <div class="tabs">
      <button class="tab-button active" onclick="openTab('informacion')">
        Información
      </button>
      <button class="tab-button" onclick="openTab('contraarchivo')">
        Contraarchivo
      </button>
    </div>

    <div id="informacion" class="tab-content active">
      <p><span class="label">Título:</span> La casa en Mango Street</p>
      <p><span class="label">Autor/a:</span> Sandra Cisneros</p>
      <p><span class="label">Condado(s):</span> Hernando</p>
      <p><span class="label">Año primero removido:</span> 2024</p>
      <p><span class="label">Temas:</span> la llegada a la madurez; identidad; pobreza; papeles de género</p>
      <p><span class="label">Grados:</span> K-12</p>

      <p>
        <span class="label">Resumen:</span> Esta es la historia de la llegada a la mayoría de edad de una niña chicana. Cuando Esperanza Cordero tenía 12 años, su familia se mudó a un barrio latino en Chicago, Illinois. La historia la sigue a ella y a sus amigos mientras crecen emocionalmente, artísticamente y sexualmente. En una serie de retratos, la autora explora la opresión, el racismo, el sexismo y la pobreza.
      </p>

      <p><span class="label">Las razones por la prohibición:</span></p>
      <div class="fill-box">
        Escribe aquí...
      </div>

      <p><span class="label">Las razones en contexto:</span></p>
      <div class="fill-box">
        Escribe aquí...
      </div>

      <p><span class="label">Resumen de “Red Clowns” de SparkNotes:</span></p>
      <div class="fill-box">
        Escribe aquí...
      </div>
    </div>

    <div id="contraarchivo" class="tab-content">
      <p><span class="label">Contraarchivo:</span></p>
      <div class="contraarchivo-box">
        Escribe aquí tu contraarchivo...
      </div>
    </div>
  </div>

  <script>
    const book = document.getElementById("book");
    const popup = document.getElementById("popup");

    let isDragging = false;
    let offsetX = 0;
    let offsetY = 0;

    book.addEventListener("mouseenter", () => {
      popup.classList.add("show");
      positionPopupNearBook();
    });

    book.addEventListener("mouseleave", () => {
      setTimeout(() => {
        if (!popup.matches(":hover") && !book.matches(":hover")) {
          popup.classList.remove("show");
        }
      }, 150);
    });

    popup.addEventListener("mouseleave", () => {
      if (!book.matches(":hover")) {
        popup.classList.remove("show");
      }
    });

    book.addEventListener("mousedown", (e) => {
      isDragging = true;
      offsetX = e.clientX - book.offsetLeft;
      offsetY = e.clientY - book.offsetTop;
      book.style.cursor = "grabbing";
    });

    document.addEventListener("mousemove", (e) => {
      if (!isDragging) return;

      book.style.left = e.clientX - offsetX + "px";
      book.style.top = e.clientY - offsetY + "px";

      positionPopupNearBook();
    });

    document.addEventListener("mouseup", () => {
      isDragging = false;
      book.style.cursor = "grab";
    });

    function positionPopupNearBook() {
      const bookRect = book.getBoundingClientRect();

      let popupLeft = bookRect.right + 20;
      let popupTop = bookRect.top;

      if (popupLeft + popup.offsetWidth > window.innerWidth) {
        popupLeft = bookRect.left - popup.offsetWidth - 20;
      }

      if (popupTop + popup.offsetHeight > window.innerHeight) {
        popupTop = window.innerHeight - popup.offsetHeight - 20;
      }

      if (popupTop < 20) {
        popupTop = 20;
      }

      popup.style.left = popupLeft + "px";
      popup.style.top = popupTop + "px";
    }

    function openTab(tabName) {
      const tabContents = document.querySelectorAll(".tab-content");
      const tabButtons = document.querySelectorAll(".tab-button");

      tabContents.forEach(content => {
        content.classList.remove("active");
      });

      tabButtons.forEach(button => {
        button.classList.remove("active");
      });

      document.getElementById(tabName).classList.add("active");

      if (tabName === "informacion") {
        tabButtons[0].classList.add("active");
      } else {
        tabButtons[1].classList.add("active");
      }
    }
  </script>

</body>
</html>
